<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href='/img/circulo - logo blanco.png' />
    <title>Financiero - Sistemas Analíticos</title>

    <!-- Bootstrap desde NuGet (via wwwroot) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons y DataTables -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" integrity="sha512-aW0Vuo46Z9+bXgbhwZtlIrY5hfPdsb+IvNQ3iMvtIKl0JgSDSFoFfcZ7gdp9oL8YIcA6QOiZreHj++olyg3BDA==" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" integrity="sha512-b6Ai4YnSM5LpNjNBvhPUrVQ2IgHCYKYnUgXPpAFmd9/zSx35YBnOKUEA3HRRMqm8dOFMVWQclQPRmEl9zD+DQw==" crossorigin="anonymous">

    <!-- Font Montserrat -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SistemasAnaliticos.styles.css" asp-append-version="true" />

    <style>
        body {
            font-family: 'Montserrat', sans-serif !important;
        }

        /* ==== NAVBAR RH PERSONALIZADO ==== */
        .navbar-rh {
            background-color: #012473;
        }

            .navbar-rh .navbar-toggler {
                border: none;
                color: white;
            }

                .navbar-rh .navbar-toggler:focus {
                    box-shadow: none;
                }

            .navbar-rh .notification-dot {
                position: absolute;
                top: 8px;
                right: 8px;
                width: 8px;
                height: 8px;
                background-color: #E00319;
                border-radius: 50%;
            }

        @@media (min-width: 992px) {
            .navbar-rh .nav-item.dropdown:hover .dropdown-menu {
                display: block;
                margin-top: 0;
            }
        }

        .navbar-rh .dropdown-menu {
            background-color: #012473;
            border: 1px solid #013599;
            border-radius: 0.375rem;
            z-index: 1050 !important;
        }

        .navbar-rh .dropdown-item {
            color: white !important;
            padding: 0.5rem 1rem;
        }

            .navbar-rh .dropdown-item:hover {
                background-color: #013599;
                color: white;
            }

        .navbar-rh .dropdown-divider {
            border-color: #013599;
        }

        .navbar-rh .nav-link {
            position: relative;
            padding: 0.5rem 1rem !important;
            border-radius: 0.375rem;
            transition: all 0.3s ease;
        }

            .navbar-rh .nav-link:hover {
                background-color: #013599;
            }

        /* Logo */
        .navbar-rh .logo-rh {
            height: 40px;
            width: auto;
            object-fit: contain;
        }

        .navbar-rh .logo-container-rh {
            transition: transform 0.3s ease;
        }

            .navbar-rh .logo-container-rh:hover {
                transform: scale(1.05);
            }

        .navbar-rh .border-primary {
            border-color: rgba(255,255,255,0.3) !important;
        }

        /* Responsive ajustes */
        @@media (max-width: 991.98px) {
            .navbar-rh .navbar-collapse {
                background-color: #012473;
                border-top: 1px solid #013599;
                padding: 1rem;
                border-radius: 0 0 0.5rem 0.5rem;
            }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-rh text-white shadow-lg">
            <div class="container-xxl px-4 px-sm-6 px-lg-8">
                <!-- Logo y marca -->
                <a class="d-flex align-items-center gap-2 logo-container-rh text-white text-decoration-none"
                   asp-controller="Home" asp-action="HomeFinanciero">
                    <img src='/Img/circulo - logo blanco.png' alt="logo-circulo" class="logo-rh">
                    <span class="fs-4 fw-bold">Departmento Financiero</span>
                </a>

                <!-- Botón responsive -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarRHCollapse"
                        aria-controls="navbarRHCollapse"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <i class="bi bi-list text-white"></i>
                </button>

                <!-- Opciones de navegación -->
                <div class="collapse navbar-collapse" id="navbarRHCollapse">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 mt-3 mt-lg-0"></ul>

                    <!-- Controles de usuario -->
                    <form asp-action="LogOut" asp-controller="Usuario" method="post">
                        <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0">
                            <div class="d-flex align-items-center gap-2 ps-3 border-start border-primary">
                                @if (User.Identity.IsAuthenticated)
                                {
                                    <span class="small">@User.Identity.Name</span>
                                }
                                else
                                {
                                    <span class="small">Usuario No Logueado</span>
                                }
                            </div>
                            <button class="btn p-2 text-white border-0">
                                <i class="bi bi-box-arrow-right fs-5"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </nav>
    </header>

    <div>
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Incluir Lottie -->
    <script src="~/lib/lottie-player/lottie-player.min.js"></script>

    <script src="~/lib/inputmask/inputmask.min.js"></script>

    <!-- jQuery (SIEMPRE primero) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous"></script>

    <!-- DataTables core -->
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js" integrity="sha512-BQ3f0AMbTpWxc4YSQm03nL5LX7mb4KhgNQfEowc6IdpylTaRuzkiChTJISQlKWaof0rIYtHRaRBEl8G6F8GxzA==" crossorigin="anonymous"></script>

    <!-- DataTables Bootstrap 5 -->
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js" integrity="sha512-zw34c1fnMeY29qzodeC+GGKfyQQ7hN+a9yjGnIAZbkPPn/Xeh8Z46uea/fjq5Mwsp4bxvGKfJrTNnh/GdIZJ1g==" crossorigin="anonymous"></script>

    <!-- Bootstrap Bundle desde NuGet -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- FontAwesome Script -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" integrity="sha512-fD9DI5bZwQxOi7MhYWnnNPlvXdp/2Pj3XSTRrFs5FQa4mizyGLnJcN6tuvUS6LbmgN1ut+XGSABKvjN0H6Aoow==" crossorigin="anonymous"></script>

    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" integrity="sha512-TA1p+I1AtmUN2QnvpJT01/hjvxCxjyBfXtNuKNnvvwyCaQpdl5JUfiJ7geQtMnJ55myntTq5JwPLiH3j6e222A==" crossorigin="anonymous"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>