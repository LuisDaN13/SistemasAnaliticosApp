@model List<SistemasAnaliticos.ViewModels.OrganigramaVM>
@{
    ViewData["Title"] = "Organigrama";
    var jsonData = System.Text.Json.JsonSerializer.Serialize(Model);
}

<style>
    .header-card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 4px 12px rgba(0,0,0,.08);
        background-color: white;
    }

    #org-container {
        width: 100%;
        height: 700px;
        background: #f8f9fa;
        border-radius: 0 0 12px 12px;
        position: relative;
    }
    /* Nodo personalizado */
    .org-node-wrap {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 2px 10px rgba(0,0,0,.10);
        width: 220px;
        cursor: pointer;
        transition: box-shadow 0.2s;
    }

        .org-node-wrap:hover {
            box-shadow: 0 6px 20px rgba(0,0,0,.18);
        }

    .org-node-header {
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .org-node-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255,255,255,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 13px;
        color: white;
        flex-shrink: 0;
    }

    .org-node-name {
        color: white;
        font-weight: 600;
        font-size: 13px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 148px;
    }

    .org-node-role {
        color: rgba(255,255,255,0.85);
        font-size: 11px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 148px;
    }

    .org-node-footer {
        padding: 5px 14px;
        font-size: 11px;
        font-weight: 500;
    }
    /* Toolbar */
    .org-btn {
        border: 1px solid #dee2e6;
        background: white;
        border-radius: 6px;
        padding: 5px 12px;
        font-size: 13px;
        cursor: pointer;
        transition: background 0.15s;
    }

        .org-btn:hover {
            background: #f0f0f0;
        }

    .org-btn-primary {
        background: #012473;
        color: white;
        border-color: #012473;
    }

        .org-btn-primary:hover {
            background: #013599;
        }
</style>

<div class="container-xxl px-4 py-4">

    <div class="header-card p-4 mt-2 mb-0">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h1 class="h2 fw-bold mb-1">Organigrama Empresarial</h1>
                <p class="text-muted mb-0">Relaciones entre jefaturas y empleados de <strong>Sistemas Analíticos</strong></p>
            </div>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <input type="text" id="org-search" class="form-control form-control-sm"
                       placeholder="Buscar empleado..." style="width:200px;" />
                <button class="org-btn" id="btn-fit">⊡ Ajustar</button>
                <button class="org-btn" id="btn-expand">↕ Expandir todo</button>
                <button class="org-btn" id="btn-collapse">↕ Colapsar</button>
                <button class="org-btn org-btn-primary" id="btn-export">⬇ PNG</button>
            </div>
        </div>
        <div class="mt-3 d-flex gap-2 flex-wrap" id="dept-legend"></div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div id="org-container"></div>
        </div>
    </div>

    <div id="detail-card" class="card border-0 shadow-sm mt-3" style="display:none;">
        <div class="card-body">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div id="det-avatar" style="
                    width:52px;height:52px;border-radius:50%;
                    display:flex;align-items:center;justify-content:center;
                    font-weight:700;font-size:17px;flex-shrink:0;"></div>
                <div>
                    <p id="det-nombre" class="mb-0 fw-semibold fs-6"></p>
                    <p id="det-puesto" class="mb-0 text-muted small"></p>
                </div>
                <button class="btn btn-sm btn-outline-secondary ms-auto"
                        onclick="document.getElementById('detail-card').style.display='none'">
                    &times;
                </button>
            </div>
            <div class="row g-2 small" id="det-grid"></div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
                document.addEventListener('DOMContentLoaded', function () {

            const RAW = @Html.Raw(jsonData);

            const PALETTES = [
                { bg:'#012473', light:'#E6F1FB', text:'#0C447C' },
                { bg:'#534AB7', light:'#EEEDFE', text:'#3C3489' },
                { bg:'#0F6E56', light:'#E1F5EE', text:'#085041' },
                { bg:'#854F0B', light:'#FAEEDA', text:'#633806' },
                { bg:'#993556', light:'#FBEAF0', text:'#72243E' },
                { bg:'#3D6B6B', light:'#E4F0F0', text:'#1F3D3D' },
            ];

            const depts = [...new Set(RAW.map(u => u.Departamento).filter(Boolean))];
            const deptColor = {};
            depts.forEach((d, i) => deptColor[d] = PALETTES[i % PALETTES.length]);

            function initials(name) {
                return (name || '').split(' ').filter(Boolean).map(w => w[0]).join('').slice(0,2).toUpperCase();
            }

            // Leyenda
            const legend = document.getElementById('dept-legend');
            depts.forEach(d => {
                const col = deptColor[d];
                const span = document.createElement('span');
                span.style.cssText = `background:${col.light};color:${col.text};border:1px solid ${col.bg};
                    font-size:12px;padding:3px 10px;border-radius:99px;font-weight:500;`;
                span.textContent = d;
                legend.appendChild(span);
            });

            // Función para detectar ciclos en el grafo
            function hasCycle(nodes) {
                const graph = new Map();
                const nodeMap = new Map();

                // Construir grafo
                nodes.forEach(node => {
                    nodeMap.set(node.id, node);
                    if (node.parentId && node.parentId !== null) {
                        if (!graph.has(node.id)) graph.set(node.id, []);
                        graph.get(node.id).push(node.parentId);
                    }
                });

                // Detectar ciclos usando DFS
                const visited = new Set();
                const recursionStack = new Set();

                function dfs(nodeId) {
                    if (!nodeMap.has(nodeId)) return false;
                    if (recursionStack.has(nodeId)) return true; // Ciclo detectado
                    if (visited.has(nodeId)) return false;

                    visited.add(nodeId);
                    recursionStack.add(nodeId);

                    const neighbors = graph.get(nodeId) || [];
                    for (const neighbor of neighbors) {
                        if (dfs(neighbor)) return true;
                    }

                    recursionStack.delete(nodeId);
                    return false;
                }

                for (const node of nodes) {
                    if (dfs(node.id)) return true;
                }
                return false;
            }

            // Función para romper ciclos (establece parentId a null para los nodos problemáticos)
            function breakCycles(nodes) {
                const nodeMap = new Map(nodes.map(n => [n.id, n]));
                const fixedNodes = nodes.map(n => ({ ...n }));

                for (const node of fixedNodes) {
                    if (node.parentId && node.parentId !== null) {
                        // Detectar si node.parentId forma un ciclo con node.id
                        let current = node.parentId;
                        let visited = new Set();
                        let hasCycle = false;

                        while (current && nodeMap.has(current) && !visited.has(current)) {
                            if (current === node.id) {
                                hasCycle = true;
                                break;
                            }
                            visited.add(current);
                            const parent = nodeMap.get(current);
                            current = parent && parent.parentId ? parent.parentId : null;
                        }

                        if (hasCycle) {
                            console.warn(`Ciclo detectado para el nodo ${node.id}, eliminando relación con padre ${node.parentId}`);
                            node.parentId = null;
                        }
                    }
                }

                return fixedNodes;
            }

            // Obtener todos los IDs existentes
            const existingIds = new Set(RAW.map(u => u.Id));

            // Crear datos iniciales
            let chartData = RAW.map(u => ({
                id: u.Id,
                parentId: (u.JefeId && existingIds.has(u.JefeId) && u.JefeId !== u.Id) ? u.JefeId : null, // Evitar auto-referencia
                name: u.Nombre,
                positionName: u.Puesto || '',
                dept: u.Departamento || '',
                email: u.CorreoEmpresa || '',
                _directSubCount: RAW.filter(x => x.JefeId === u.Id && x.Id !== u.Id).length
            }));

            // Romper ciclos si existen
            if (hasCycle(chartData)) {
                console.warn("Se detectaron ciclos en la jerarquía. Rompiendo ciclos...");
                chartData = breakCycles(chartData);
            }

            // Contar cuántas raíces hay (parentId = null o parentId no existe)
            let roots = chartData.filter(d => d.parentId === null || d.parentId === '');

            // Si no hay raíces, buscar nodos que no tienen padres válidos
            if (roots.length === 0) {
                const validParentIds = new Set(chartData.map(d => d.id));
                roots = chartData.filter(d => !validParentIds.has(d.parentId));
                roots.forEach(r => r.parentId = null);
            }

            let finalData;

            if (roots.length === 0 && chartData.length > 0) {
                // Si no hay raíces después de todo, crear una raíz virtual
                const rootId = 'root_virtual_' + Date.now();
                const virtualRoot = {
                    id: rootId,
                    parentId: null,
                    name: 'Organigrama General',
                    positionName: 'Dirección General',
                    dept: 'Administración',
                    email: '',
                    _directSubCount: chartData.length,
                    isVirtual: true
                };

                chartData = chartData.map(node => {
                    if (node.parentId === null || node.parentId === '') {
                        return { ...node, parentId: rootId };
                    }
                    return node;
                });

                finalData = [virtualRoot, ...chartData];
            } else if (roots.length === 1) {
                // Exactamente una raíz, usar datos directamente
                finalData = chartData;
            } else if (roots.length > 1) {
                // Múltiples raíces, crear nodo virtual
                const rootId = 'root_virtual_' + Date.now();
                const virtualRoot = {
                    id: rootId,
                    parentId: null,
                    name: 'Organigrama General',
                    positionName: 'Dirección General',
                    dept: 'Administración',
                    email: '',
                    _directSubCount: roots.length,
                    isVirtual: true
                };

                chartData = chartData.map(node => {
                    if (node.parentId === null || node.parentId === '') {
                        return { ...node, parentId: rootId };
                    }
                    return node;
                });

                finalData = [virtualRoot, ...chartData];
            } else {
                finalData = chartData;
            }

            console.log('Datos procesados:', finalData);
            console.log('Número de nodos:', finalData.length);
            console.log('Raíces encontradas:', roots.length);

            // Verificar que no haya ciclos después del procesamiento
            if (hasCycle(finalData)) {
                console.error("Aún hay ciclos en los datos después del procesamiento");
                finalData = breakCycles(finalData);
            }

            // Inicializar chart
            const chart = new d3.OrgChart()
                .container('#org-container')
                .data(finalData)
                .nodeWidth(() => 224)
                .nodeHeight(() => 90)
                .childrenMargin(() => 60)
                .compactMarginBetween(() => 35)
                .compactMarginPair(() => 30)
                .siblingsMargin(() => 30)
                .nodeContent(function(d) {
                    // Si es nodo virtual, mostrar un estilo especial
                    if (d.data.isVirtual) {
                        return `
                        <div class="org-node-wrap" style="border:2px solid #012473; background: linear-gradient(135deg, #012473, #013599);">
                            <div class="org-node-header" style="background:transparent;">
                                <div class="org-node-avatar" style="background:rgba(255,255,255,0.3);">🏢</div>
                                <div style="overflow:hidden;">
                                    <div class="org-node-name" style="color:white;">${d.data.name}</div>
                                    <div class="org-node-role" style="color:rgba(255,255,255,0.9);">${d.data.positionName}</div>
                                </div>
                            </div>
                            <div class="org-node-footer" style="background:rgba(255,255,255,0.95);color:#012473;">
                                ${d.data.dept}
                            </div>
                        </div>`;
                    }

                    const col = deptColor[d.data.dept] || PALETTES[5];
                    const ini = initials(d.data.name);
                    return `
                    <div class="org-node-wrap" style="border:2px solid ${col.bg};">
                        <div class="org-node-header" style="background:${col.bg};">
                            <div class="org-node-avatar">${ini}</div>
                            <div style="overflow:hidden;">
                                <div class="org-node-name">${d.data.name || ''}</div>
                                <div class="org-node-role">${d.data.positionName || ''}</div>
                            </div>
                        </div>
                        <div class="org-node-footer" style="background:${col.light};color:${col.text};">
                            ${d.data.dept || '&nbsp;'}
                        </div>
                    </div>`;
                })
                .onNodeClick(function(d) {
                    // Si es nodo virtual, mostrar mensaje especial
                    if (d.data.isVirtual) {
                        document.getElementById('det-avatar').style.background = '#012473';
                        document.getElementById('det-avatar').style.color = 'white';
                        document.getElementById('det-avatar').textContent = '🏢';
                        document.getElementById('det-nombre').textContent = d.data.name;
                        document.getElementById('det-puesto').textContent = d.data.positionName;
                        document.getElementById('det-grid').innerHTML = `
                            <div class="col-12">
                                <span class="text-muted">Nodo raíz del organigrama</span><br>
                                <strong>Agrupa todas las direcciones y departamentos</strong>
                            </div>
                        `;
                        document.getElementById('detail-card').style.display = 'block';
                        return;
                    }

                    const emp = RAW.find(u => u.Id === d.data.id);
                    if (!emp) return;
                    const col = deptColor[emp.Departamento] || PALETTES[5];
                    const av = document.getElementById('det-avatar');
                    av.style.background = col.bg;
                    av.style.color = 'white';
                    av.textContent = initials(emp.Nombre);
                    document.getElementById('det-nombre').textContent = emp.Nombre;
                    document.getElementById('det-puesto').textContent = emp.Puesto;
                    const jefe = RAW.find(u => u.Id === emp.JefeId);
                    const subs = RAW.filter(u => u.JefeId === emp.Id && u.Id !== emp.Id);
                    document.getElementById('det-grid').innerHTML = `
                        <div class="col-6"><span class="text-muted">Departamento</span><br><strong>${emp.Departamento||'—'}</strong></div>
                        <div class="col-6"><span class="text-muted">Correo</span><br><a href="mailto:${emp.CorreoEmpresa}" class="text-decoration-none">${emp.CorreoEmpresa||'—'}</a></div>
                        <div class="col-6"><span class="text-muted">Reporta a</span><br><strong>${jefe ? jefe.Nombre : 'Dirección General'}</strong></div>
                        <div class="col-6"><span class="text-muted">Equipo directo</span><br><strong>${subs.length ? subs.map(s=>s.Nombre).join(', ') : 'Sin reportes'}</strong></div>
                    `;
                    document.getElementById('detail-card').style.display = 'block';
                    document.getElementById('detail-card').scrollIntoView({ behavior:'smooth', block:'nearest' });
                })
                .render();

            // Búsqueda
            document.getElementById('org-search').addEventListener('input', function() {
                const q = this.value.trim();
                chart.clearHighlighting();
                if (q) {
                    finalData.forEach(d => {
                        if (d.isVirtual) return;
                        if ((d.name && d.name.toLowerCase().includes(q.toLowerCase())) ||
                            (d.positionName && d.positionName.toLowerCase().includes(q.toLowerCase()))) {
                            chart.setHighlighted(d.id);
                        }
                    });
                }
            });

            // Botones
            document.getElementById('btn-fit').addEventListener('click', () => chart.fit());
            document.getElementById('btn-expand').addEventListener('click', () => chart.expandAll().fit());
            document.getElementById('btn-collapse').addEventListener('click', () => chart.collapseAll().render().fit());
            document.getElementById('btn-export').addEventListener('click', () => chart.exportImg({ full: true }));

        });
    </script>
}
