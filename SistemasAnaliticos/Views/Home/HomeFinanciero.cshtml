@model SistemasAnaliticos.ViewModels.HomeIndexViewModel

@{
    Layout = "~/Views/Shared/_LayoutFinanciero.cshtml";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        html, body {
            height: 100%;
            margin: 0;
            overflow: hidden;
        }

        .row {
            margin: 0 !important;
        }

        .bg-gradient-custom {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        }

        :root {
            --primary-color: #012473;
            --secondary-color: #013599;
            --danger-color: #E00319;
            --success-color: #198754;
        }

        .bg-main {
            background-color: #012473;
        }

        .btn-card {
            border-radius: 16px;
            transition: all 0.2s ease;
        }

            .btn-card:hover {
                transform: scale(1.02);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            }

        .btn-primary-custom {
            background-color: #012473;
            color: white;
        }

            .btn-primary-custom:hover {
                background-color: #15224d;
            }

        .icon-box {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .icon-lg {
            width: 60px;
            height: 60px;
        }

        .geo-left-panel {
            position: relative;
            overflow: hidden;
            background: #0b1628;
        }

        /* Canvas ocupa todo */
        .geo-canvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
        }

        /* Overlay igual a Next.js */
        .overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient( to right, rgba(11, 22, 40, 0.85), rgba(11, 22, 40, 0.4) );
            z-index: 2;
        }

        /* Icono glass */
        .icon-box {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body class="bg-gradient-custom min-vh-100">

    <!-- Main Content -->
    <div class="row g-0 vh-100">

        <!-- LEFT PANEL -->
        <div class="col-lg-4 d-none d-lg-flex position-relative p-0 geo-left-panel">

            <!-- CANVAS BACKGROUND -->
            <canvas id="geoCanvas" class="geo-canvas"></canvas>

            <!-- OVERLAY (igual que tu diseño original) -->
            <div class="overlay d-flex flex-column justify-content-center px-5">
            </div>
        </div>

        <!-- RIGHT PANEL -->
        <div class="col-lg-8 d-flex align-items-center">
            <div class="w-100 px-4 px-lg-5">

                <!-- TEXT -->
                <div class="mb-4">
                    <h2 class="fw-bold">Seleccione una opción</h2>
                    <p class="text-muted">Administre sus garantías de forma rápida y segura</p>
                </div>

                <!-- BUTTONS -->
                <div class="d-grid gap-3">

                    <!-- VOLVER -->
                    <a asp-controller="Home" asp-action="HomeInicial" class="text-decoration-none">
                        <div class="p-3 border btn-card d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <div class="icon-box bg-light">
                                    <i class="bi bi-house" style="color: #012473"></i>
                                </div>
                                <div>
                                    <div class="fw-bold" style="color: #012473">Volver al Menú Inicial</div>
                                    <small class="text-muted">Regresar a la página principal</small>
                                </div>
                            </div>
                            <i class="bi bi-chevron-right"></i>
                        </div>
                    </a>

                    <!-- CREAR -->
                    <buttom class="text-decoration-none" data-bs-toggle="modal" data-bs-target="#createGarantiaModal">
                        <div class="p-3 btn-primary-custom btn-card d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <div class="icon-box icon-lg bg-white bg-opacity-25 text-white">
                                    <i class="bi bi-file-earmark-plus fs-4"></i>
                                </div>
                                <div>
                                    <div class="fw-bold">Crear Garantía</div>
                                    <small class="text-white-50">Registrar una nueva garantía</small>
                                </div>
                            </div>
                            <i class="bi bi-chevron-right"></i>
                        </div>
                    </buttom>

                    <!-- REGISTROS -->
                    <a asp-controller="Garantia" asp-action="VerGarantias" class="text-decoration-none">
                        <div class="p-3 border btn-card d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <div class="icon-box bg-primary bg-opacity-10 text-primary">
                                    <i class="bi bi-clipboard-data" style="color: #012473"></i>
                                </div>
                                <div>
                                    <div class="fw-bold" style="color: #012473">Ver Registros</div>
                                    <small class="text-muted">Consultar garantías existentes</small>
                                </div>
                            </div>
                            <i class="bi bi-chevron-right"></i>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <partial name="~/Views/Garantia/modalRegistroGarantia.cshtml" model="new SistemasAnaliticos.ViewModels.GarantiaRegistroViewModel()" />
 
    @section Scripts {
        <script>
            const cv = document.getElementById('geoCanvas');
            const cx = cv.getContext('2d');

            function resize() {
                cv.width = cv.offsetWidth;
                cv.height = cv.offsetHeight;
                draw();
            }

            function poly(pts) {
                cx.beginPath();
                cx.moveTo(pts[0][0], pts[0][1]);
                for (let i = 1; i < pts.length; i++) {
                    cx.lineTo(pts[i][0], pts[i][1]);
                }
                cx.closePath();
            }

            function draw() {
                const W = cv.width, H = cv.height;
                cx.clearRect(0, 0, W, H);

                cx.fillStyle = '#0b1628';
                cx.fillRect(0, 0, W, H);

                const shapes = [
                    { pts: [[0,0],[W*0.55,0],[W*0.3,H*0.45],[0,H*0.3]], color: '#1a3058' },
                    { pts: [[W*0.55,0],[W,0],[W,H*0.38],[W*0.62,H*0.22]], color: '#213870' },
                    { pts: [[W,0],[W,H*0.38],[W*0.62,H*0.22],[W*0.78,0]], color: '#2a4880' },
                    { pts: [[0,H*0.3],[W*0.3,H*0.45],[W*0.18,H*0.72],[0,H*0.6]], color: '#162848' },
                    { pts: [[W*0.3,H*0.45],[W*0.62,H*0.22],[W*0.85,H*0.5],[W*0.5,H*0.68]], color: '#2e507a' },
                    { pts: [[W*0.62,H*0.22],[W,H*0.38],[W,H*0.65],[W*0.85,H*0.5]], color: '#3a608e' },
                    { pts: [[0,H*0.6],[W*0.18,H*0.72],[W*0.1,H],[0,H]], color: '#1c3360' },
                    { pts: [[W*0.18,H*0.72],[W*0.5,H*0.68],[W*0.38,H],[W*0.1,H]], color: '#253f68' },
                    { pts: [[W*0.5,H*0.68],[W*0.85,H*0.5],[W,H*0.65],[W*0.72,H],[W*0.38,H]], color: '#1e3a5f' },
                    { pts: [[W*0.85,H*0.5],[W,H*0.65],[W,H],[W*0.72,H]], color: '#4a6e96' },
                    { pts: [[W*0.3,H*0.45],[W*0.5,H*0.68],[W*0.18,H*0.72],[0,H*0.6],[0,H*0.3]], color: '#182c4e' },
                    { pts: [[W*0.55,0],[W*0.78,0],[W*0.62,H*0.22]], color: '#4060a0' },
                    { pts: [[0,0],[W*0.18,0],[W*0.08,H*0.18],[0,H*0.12]], color: '#243c6a' },
                ];

                shapes.forEach(s => {
                    poly(s.pts);
                    cx.fillStyle = s.color;
                    cx.fill();
                });

                shapes.forEach(s => {
                    poly(s.pts);
                    cx.strokeStyle = 'rgba(255,255,255,0.04)';
                    cx.lineWidth = 0.8;
                    cx.stroke();
                });

                const vignette = cx.createRadialGradient(W*0.4, H*0.45, H*0.05, W*0.4, H*0.45, H*0.9);
                vignette.addColorStop(0, 'rgba(0,0,0,0)');
                vignette.addColorStop(1, 'rgba(0,0,0,0.45)');
                cx.fillStyle = vignette;
                cx.fillRect(0, 0, W, H);
            }

            window.addEventListener('resize', resize);
            resize();
        </script>

        <!-- Respuestas de los Formularios -->
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                // Para mensajes de error
                @if (TempData["ErrorMessageHome"] != null)
                {
                    <text>
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: '@Html.Raw(TempData["ErrorMessageHome"])',
                            confirmButtonText: 'Aceptar'
                        });
                    </text>
                }

                // Para mensajes de éxito
                @if (TempData["SuccessMessageHome"] != null)
                {
                    <text>
                        Swal.fire({
                            icon: 'success',
                            title: 'Éxito',
                            text: '@Html.Raw(TempData["SuccessMessageHome"])',
                            confirmButtonText: 'Aceptar',
                            timer: 3000
                        });
                    </text>
                }
            });
        </script>

        <!-- Modal para primer login -->
        <div class="modal fade" id="firstLoginPasswordModal" tabindex="-1" aria-labelledby="firstLoginPasswordModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title" id="firstLoginPasswordModalLabel">
                            <i class="bi bi-shield-exclamation"></i> Cambio de Contraseña Requerido
                        </h5>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i>
                            <strong>Primer inicio de sesión detectado.</strong><br>
                            Por seguridad, debe cambiar su contraseña antes de continuar.
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nueva Contraseña</label>
                            <div class="input-group">
                                <input type="password"
                                       class="form-control"
                                       id="firstLoginNewPassword"
                                       placeholder="Ingrese nueva contraseña"
                                       required>
                                <button class="btn btn-outline-secondary" type="button" id="toggleFirstLoginPassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <div class="form-text">
                                <small>Debe contener: 8+ caracteres, mayúscula, minúscula, número y carácter especial.</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Confirmar Contraseña</label>
                            <div class="input-group">
                                <input type="password"
                                       class="form-control"
                                       id="firstLoginConfirmPassword"
                                       placeholder="Confirme la contraseña"
                                       required>
                                <button class="btn btn-outline-secondary" type="button" id="toggleFirstLoginConfirm">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <div id="firstLoginPasswordError" class="text-danger small mt-1"></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-primary" id="btnFirstLoginChangePassword">
                            <i class="bi bi-key"></i> Cambiar Contraseña
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            $(document).ready(function () {
                // Verificar TempData para mostrar modal
                var showModal = '@(TempData["ShowPasswordChangeModal"] ?? "")';
                var userId = '@(TempData["FirstLoginUserId"] ?? "")';

                if (showModal === "true" && userId) {
                    console.log("Mostrando modal de cambio de contraseña");

                    // Mostrar el modal después de un pequeño delay
                    setTimeout(function() {
                        var modalElement = document.getElementById('firstLoginPasswordModal');
                        if (modalElement) {
                            var modal = new bootstrap.Modal(modalElement, {
                                backdrop: 'static',
                                keyboard: false
                            });
                            modal.show();

                            // Limpiar TempData
                            @{
                                    TempData.Remove("ShowPasswordChangeModal");
                                    TempData.Remove("FirstLoginUserId");
                            }
                        }
                    }, 1000); // Delay de 1 segundo para asegurar que todo esté cargado
                }

                // Toggle para mostrar/ocultar contraseña
                $('#toggleFirstLoginPassword').click(function() {
                    var input = $('#firstLoginNewPassword');
                    var icon = $(this).find('i');
                    togglePasswordVisibility(input, icon);
                });

                $('#toggleFirstLoginConfirm').click(function() {
                    var input = $('#firstLoginConfirmPassword');
                    var icon = $(this).find('i');
                    togglePasswordVisibility(input, icon);
                });

                function togglePasswordVisibility(input, icon) {
                    if (input.attr('type') === 'password') {
                        input.attr('type', 'text');
                        icon.removeClass('bi-eye').addClass('bi-eye-slash');
                    } else {
                        input.attr('type', 'password');
                        icon.removeClass('bi-eye-slash').addClass('bi-eye');
                    }
                }

                // Manejar el cambio de contraseña
                $('#btnFirstLoginChangePassword').click(function() {
                    handleFirstLoginPasswordChange(userId);
                });

                function handleFirstLoginPasswordChange(userId) {
                    var newPass = $('#firstLoginNewPassword').val();
                    var confirmPass = $('#firstLoginConfirmPassword').val();
                    var errorDiv = $('#firstLoginPasswordError');

                    // Reset error
                    errorDiv.text('').hide();

                    // Validaciones
                    if (!newPass || !confirmPass) {
                        errorDiv.text('Ambos campos son obligatorios.').show();
                        return;
                    }

                    if (newPass !== confirmPass) {
                        errorDiv.text('Las contraseñas no coinciden.').show();
                        return;
                    }

                    // Validar patrón
                    var passwordPattern = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@@$!%*?&#._-])[A-Za-z\d@@$!%*?&#._-]{8,}$/;
                    if (!passwordPattern.test(newPass)) {
                        errorDiv.text('La contraseña no cumple los requisitos de seguridad.').show();
                        return;
                    }

                    // Deshabilitar botón y mostrar loading
                    var btn = $('#btnFirstLoginChangePassword');
                    btn.prop('disabled', true);
                    var originalText = btn.html();
                    btn.html('<span class="spinner-border spinner-border-sm"></span> Procesando...');

                    // Enviar AJAX
                    $.ajax({
                        url: '@Url.Action("CambiarContrasena2", "Usuario")',
                        type: 'POST',
                        data: {
                            Id: userId,
                            NuevaContrasena: newPass,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                if (response.logout) {
                                    // Mostrar mensaje de éxito y redirigir
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Contraseña Cambiada',
                                        text: response.message,
                                        confirmButtonText: 'OK'
                                    }).then(() => {
                                        window.location.href = '@Url.Action("Login", "Usuario")';
                                    });
                                } else {
                                    Swal.fire({
                                        icon: 'success',
                                        title: '¡Éxito!',
                                        text: response.message,
                                        confirmButtonText: 'OK'
                                    }).then(() => {
                                        $('#firstLoginPasswordModal').modal('hide');
                                        window.location.reload();
                                    });
                                }
                            } else {
                                errorDiv.text(response.message || 'Error al cambiar la contraseña.').show();
                                btn.prop('disabled', false).html(originalText);
                            }
                        },
                        error: function(xhr) {
                            var errorMessage = 'Error de conexión. Intente nuevamente.';
                            if (xhr.responseJSON && xhr.responseJSON.message) {
                                errorMessage = xhr.responseJSON.message;
                            }
                            errorDiv.text(errorMessage).show();
                            btn.prop('disabled', false).html(originalText);
                        }
                    });
                }
            });
        </script>
    }
</body>
</html>